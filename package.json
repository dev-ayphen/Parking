{
  "name": "parkswift",
  "version": "0.1.0",
  "description": "ParkSwift - Parking management platform",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "bash dev.sh",
    "nx": "nx",
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@nx/eslint": "18.3.5",
    "@nx/eslint-plugin": "18.3.5",
    "@nx/jest": "18.3.5",
    "@nx/js": "18.3.5",
    "@nx/workspace": "^18.2.0",
    "@swc-node/register": "~1.8.0",
    "@swc/core": "~1.3.85",
    "@swc/helpers": "~0.5.2",
    "@types/jest": "^29.4.0",
    "@types/node": "18.16.9",
    "@typescript-eslint/eslint-plugin": "^7.3.0",
    "@typescript-eslint/parser": "^7.3.0",
    "concurrently": "^10.0.3",
    "eslint": "~8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "jest": "^29.4.1",
    "jest-environment-node": "^29.4.1",
    "nx": "^18.2.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  }
}
